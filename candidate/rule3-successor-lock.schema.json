{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://concordance.local/schemas/rule3-successor-lock-1.0.0.json",
  "title": "Concordance Rule 3 Divergence Successor Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "pool_id",
    "pool_size",
    "rule_version",
    "content_version",
    "private_root",
    "bindings",
    "parent",
    "candidates",
    "models",
    "plans",
    "execution_policy",
    "budget",
    "threshold",
    "network_policy",
    "paid_authorization",
    "execution_sources"
  ],
  "properties": {
    "schema_version": {"const": "rule3-successor-lock-1.0.0"},
    "status": {"const": "immutable-successor-preexecution-lock-no-spending-authorized"},
    "pool_id": {"const": "concordance-divergence-replacement-1"},
    "pool_size": {"const": 1},
    "rule_version": {"const": "pilot-rule-3-successor-1"},
    "content_version": {"const": "rule3-successor-candidate-1.0.1"},
    "private_root": {"const": ".pilot/divergence-successor/concordance-divergence-replacement-1"},
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "source_freeze", "protocol", "models_config", "lock_schema", "old_rule3_lock"],
      "properties": {
        "question": {"$ref": "#/$defs/binding"},
        "source_freeze": {"$ref": "#/$defs/binding"},
        "protocol": {
          "allOf": [
            {"$ref": "#/$defs/binding"},
            {
              "type": "object",
              "required": ["protocol_version"],
              "properties": {"protocol_version": {"const": "rule3-successor-1.0.0"}}
            }
          ]
        },
        "models_config": {"$ref": "#/$defs/binding"},
        "lock_schema": {"$ref": "#/$defs/binding"},
        "old_rule3_lock": {"$ref": "#/$defs/binding"}
      }
    },
    "parent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule3_lock", "corrected_galatians_lineage", "quantum_run", "quantum_disposition", "historical_artifacts_preserved", "old_pool_extended", "old_responses_reused"],
      "properties": {
        "rule3_lock": {"$ref": "#/$defs/binding"},
        "corrected_galatians_lineage": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/binding"}
        },
        "quantum_run": {"$ref": "#/$defs/binding"},
        "quantum_disposition": {"$ref": "#/$defs/binding"},
        "historical_artifacts_preserved": {"const": true},
        "old_pool_extended": {"const": false},
        "old_responses_reused": {"const": false}
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "kind", "path", "sha256"],
        "properties": {
          "id": {"const": "frontier-ai-lifecycle-licensing"},
          "role": {"const": "replacement"},
          "kind": {"const": "divergent"},
          "path": {"const": "candidate/rule3-successor/questions/frontier-ai-lifecycle-licensing.json"},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "models": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {"$ref": "#/$defs/model"}
    },
    "plans": {
      "type": "object",
      "additionalProperties": false,
      "required": ["call_type", "variant_id", "candidate_plans", "ordered_universe_plan_sha256"],
      "properties": {
        "call_type": {"const": "answer"},
        "variant_id": {"const": "default"},
        "candidate_plans": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["candidate_id", "role", "cell_count", "cells", "plan_sha256"],
            "properties": {
              "candidate_id": {"const": "frontier-ai-lifecycle-licensing"},
              "role": {"const": "replacement"},
              "cell_count": {"const": 8},
              "cells": {
                "type": "array",
                "minItems": 8,
                "maxItems": 8,
                "items": {"$ref": "#/$defs/cell"}
              },
              "plan_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        "ordered_universe_plan_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["call_type", "cells", "preflight_requests_per_model", "generation_posts_per_model", "attempts_per_cell", "automatic_retries", "all_preflights_must_succeed_before_generation", "generation_parallel_after_gate", "intent_before_request", "raw_response_before_validation", "no_capture_attempt_is_consumed_and_terminal", "output_token_cap", "tools_enabled", "web_search_enabled", "retrieval_enabled", "external_context_enabled"],
      "properties": {
        "call_type": {"const": "answer"},
        "cells": {"const": 8},
        "preflight_requests_per_model": {"const": 1},
        "generation_posts_per_model": {"const": 1},
        "attempts_per_cell": {"const": 1},
        "automatic_retries": {"const": 0},
        "all_preflights_must_succeed_before_generation": {"const": true},
        "generation_parallel_after_gate": {"const": true},
        "intent_before_request": {"const": true},
        "raw_response_before_validation": {"const": true},
        "no_capture_attempt_is_consumed_and_terminal": {"const": true},
        "output_token_cap": {"const": 16384},
        "tools_enabled": {"const": false},
        "web_search_enabled": {"const": false},
        "retrieval_enabled": {"const": false},
        "external_context_enabled": {"const": false}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["historical_reserved_microdollars", "historical_spend_is_informational_only", "new_candidate_cap_microdollars", "new_pool_cap_microdollars", "lock_authorizes_spending"],
      "properties": {
        "historical_reserved_microdollars": {"type": "integer", "minimum": 0},
        "historical_spend_is_informational_only": {"const": true},
        "new_candidate_cap_microdollars": {"const": 6000000},
        "new_pool_cap_microdollars": {"const": 6000000},
        "lock_authorizes_spending": {"const": false}
      }
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_completed_responses", "minimum_non_null_primary_endorsements", "minimum_distinct_primary_positions", "maximum_primary_endorsements_per_position"],
      "properties": {
        "required_completed_responses": {"const": 8},
        "minimum_non_null_primary_endorsements": {"const": 6},
        "minimum_distinct_primary_positions": {"const": 3},
        "maximum_primary_endorsements_per_position": {"const": 4}
      }
    },
    "network_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_preflight_gets", "maximum_generation_posts", "maximum_outbound_requests", "authorized_hosts", "unlisted_network_access_allowed"],
      "properties": {
        "maximum_preflight_gets": {"const": 8},
        "maximum_generation_posts": {"const": 8},
        "maximum_outbound_requests": {"const": 16},
        "authorized_hosts": {
          "const": ["generativelanguage.googleapis.com", "api.anthropic.com", "api.cohere.com", "api.deepinfra.com", "api.deepseek.com", "api.mistral.ai", "api.x.ai", "openrouter.ai"]
        },
        "unlisted_network_access_allowed": {"const": false}
      }
    },
    "paid_authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "enabled", "lock_authorizes_spending", "exact_author_approval_committed", "authorization_statement", "authorization_statement_sha256", "fresh_official_pricing_recheck_required", "private_authorization_write_allowed", "provider_calls_allowed"],
      "properties": {
        "required": {"const": true},
        "enabled": {"const": false},
        "lock_authorizes_spending": {"const": false},
        "exact_author_approval_committed": {"const": false},
        "authorization_statement": {"type": "null"},
        "authorization_statement_sha256": {"type": "null"},
        "fresh_official_pricing_recheck_required": {"const": true},
        "private_authorization_write_allowed": {"const": false},
        "provider_calls_allowed": {"const": false}
      }
    },
    "execution_sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/binding"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "binding": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_key", "family", "provider", "requested_model_id", "route", "environment_variable", "api_style", "base_url", "generation_path", "metadata_path", "metadata_mode", "auth_kind", "fallback_allowed", "requests_per_second", "requested_params", "planning_pricing"],
      "properties": {
        "model_key": {"enum": ["gemini", "claude", "cohere", "qwen", "deepseek", "mistral", "grok", "gpt"]},
        "family": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "minLength": 1},
        "requested_model_id": {"type": "string", "minLength": 1},
        "route": {"type": "string", "minLength": 1},
        "environment_variable": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "api_style": {"type": "string", "minLength": 1},
        "base_url": {"type": "string", "pattern": "^https://"},
        "generation_path": {"type": "string", "pattern": "^/"},
        "metadata_path": {"type": "string", "pattern": "^/"},
        "metadata_mode": {"type": "string", "minLength": 1},
        "auth_kind": {"type": "string", "minLength": 1},
        "fallback_allowed": {"const": false},
        "requests_per_second": {"type": "number", "exclusiveMinimum": 0},
        "requested_params": {"type": "object"},
        "planning_pricing": {"type": "object"}
      }
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cell_id", "model_key", "prompt_sha256", "requested_model_id", "route", "requested_params", "semantic_attempt_number", "maximum_generation_posts"],
      "properties": {
        "cell_id": {"type": "string", "pattern": "^frontier-ai-lifecycle-licensing:"},
        "model_key": {"enum": ["gemini", "claude", "cohere", "qwen", "deepseek", "mistral", "grok", "gpt"]},
        "prompt_sha256": {"$ref": "#/$defs/sha256"},
        "requested_model_id": {"type": "string", "minLength": 1},
        "route": {"type": "string", "minLength": 1},
        "requested_params": {"type": "object"},
        "semantic_attempt_number": {"const": 1},
        "maximum_generation_posts": {"const": 1}
      }
    }
  }
}
