{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://concordance.local/schemas/rule3-successor-continuation-review-lock-2.0.0.json",
  "title": "Rule 3 successor continuation author-review lock v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "pool_id",
    "candidate_id",
    "private_root",
    "lineage",
    "private_inputs",
    "consensus",
    "review_contract",
    "offline_policy",
    "assets",
    "sources"
  ],
  "properties": {
    "schema_version": {"const": "rule3-successor-continuation-review-lock-2.0.0"},
    "status": {"const": "sealed-continuation-author-review-v2"},
    "pool_id": {"const": "frontier-ai-preflight-correction-1"},
    "candidate_id": {"const": "frontier-ai-lifecycle-licensing"},
    "private_root": {"const": ".pilot/divergence-successor-continuation-author-review/frontier-ai-preflight-correction-1"},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["historical_git_head", "base_public_bindings", "base_continuation_lock", "composite", "blind_packet", "blind_crosswalk", "blind_key_sha256", "question_sha256", "plan_sha256", "authorization_receipt_sha256", "pricing_recheck_receipt_sha256", "offline_correction_sha256"],
      "properties": {
        "historical_git_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "base_public_bindings": {
          "type": "object",
          "additionalProperties": false,
          "required": ["lock_schema", "question", "protocol", "models_config"],
          "properties": {
            "lock_schema": {"$ref": "#/$defs/binding"},
            "question": {"$ref": "#/$defs/binding"},
            "protocol": {"$ref": "#/$defs/binding"},
            "models_config": {"$ref": "#/$defs/binding"}
          }
        },
        "base_continuation_lock": {"$ref": "#/$defs/binding"},
        "composite": {"$ref": "#/$defs/binding"},
        "blind_packet": {"$ref": "#/$defs/binding"},
        "blind_crosswalk": {"$ref": "#/$defs/binding"},
        "blind_key_sha256": {"$ref": "#/$defs/sha"},
        "question_sha256": {"$ref": "#/$defs/sha"},
        "plan_sha256": {"$ref": "#/$defs/sha"},
        "authorization_receipt_sha256": {"$ref": "#/$defs/sha"},
        "pricing_recheck_receipt_sha256": {"$ref": "#/$defs/sha"},
        "offline_correction_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "private_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_anchor", "first_pass_mapping", "first_pass_receipt"],
      "properties": {
        "review_anchor": {"$ref": "#/$defs/binding"},
        "first_pass_mapping": {"$ref": "#/$defs/binding"},
        "first_pass_receipt": {"$ref": "#/$defs/binding"}
      }
    },
    "consensus": {
      "type": "object",
      "required": ["mapper_role", "item_count", "packet_order_preserved", "assignment_hashes"],
      "additionalProperties": false,
      "properties": {
        "mapper_role": {"const": "two-independent-blinded-mappers-consensus-v2"},
        "item_count": {"const": 8},
        "packet_order_preserved": {"const": true},
        "assignment_hashes": {"type": "array", "minItems": 8, "maxItems": 8, "uniqueItems": true, "items": {"$ref": "#/$defs/sha"}}
      }
    },
    "review_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "author_packet_schema", "author_export_schema", "author_receipt_schema", "decision_values", "reason_codes", "identity_blinded", "canonical_position_ids_allowed", "response_text_exported", "author_packet_requires_committed_review_lock"],
      "properties": {
        "reviewer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "display_name"],
          "properties": {
            "id": {"const": "ag-elrod"},
            "display_name": {"const": "A.G. Elrod"}
          }
        },
        "author_packet_schema": {"const": "divergence-successor-author-review-packet-2.0.0"},
        "author_export_schema": {"const": "divergence-successor-author-review-draft-2.0.0"},
        "author_receipt_schema": {"const": "divergence-successor-author-review-receipt-2.0.0"},
        "decision_values": {"const": ["confirm", "correct"]},
        "reason_codes": {"const": ["clear_preference", "mixed", "outside_map", "refusal", "unclear"]},
        "identity_blinded": {"const": true},
        "canonical_position_ids_allowed": {"const": false},
        "response_text_exported": {"const": false},
        "author_packet_requires_committed_review_lock": {"const": true}
      }
    },
    "offline_policy": {
      "type": "object",
      "required": ["network_requests", "environment_variables_read", "provider_calls", "tools_enabled", "web_search_enabled", "retrieval_enabled", "external_context_enabled", "threshold_evaluation"],
      "properties": {
        "network_requests": {"const": 0},
        "environment_variables_read": {"const": 0},
        "provider_calls": {"const": 0},
        "tools_enabled": {"const": false},
        "web_search_enabled": {"const": false},
        "retrieval_enabled": {"const": false},
        "external_context_enabled": {"const": false},
        "threshold_evaluation": {"const": {"performed": false}}
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locked_sources", "versioned_derivatives", "css_derivation", "javascript_derivation"],
      "properties": {
        "locked_sources": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/binding"}},
        "versioned_derivatives": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/binding"}},
        "css_derivation": {"const": "byte-identical"},
        "javascript_derivation": {"const": "three-exact-literal-v2-adapter"}
      }
    },
    "sources": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/binding"}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"}
      }
    }
  }
}
