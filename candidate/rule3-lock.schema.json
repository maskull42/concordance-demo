{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rule3-lock-1.0.0",
  "title": "Concordance immutable Rule 3 execution lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "pool_id",
    "pool_size",
    "rule_version",
    "content_version",
    "bindings",
    "candidates",
    "models",
    "plans",
    "execution_policy",
    "threshold",
    "state_transition_contract",
    "paid_authorization",
    "execution_sources"
  ],
  "properties": {
    "schema_version": { "const": "rule3-lock-1.0.0" },
    "status": {
      "const": "immutable-preexecution-lock-no-spending-authorized"
    },
    "pool_id": { "const": "concordance-divergence-supplement-1" },
    "pool_size": { "const": 2 },
    "rule_version": { "const": "pilot-rule-3" },
    "content_version": { "const": "rule3-candidate-1.0.0" },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dossier",
        "source_freeze",
        "mapping_rubric",
        "protocol",
        "models_config",
        "pricing_review",
        "lock_schema"
      ],
      "properties": {
        "dossier": {
          "$ref": "#/$defs/binding",
          "properties": {
            "path": { "const": "candidate/DIVERGENCE_SUPPLEMENT_RESEARCH.md" }
          }
        },
        "source_freeze": {
          "$ref": "#/$defs/binding",
          "properties": {
            "path": { "const": "candidate/rule3/source-freeze.json" }
          }
        },
        "mapping_rubric": {
          "$ref": "#/$defs/binding",
          "properties": {
            "path": { "const": "candidate/MAPPING_RUBRIC.md" }
          }
        },
        "protocol": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "protocol_version", "sha256"],
          "properties": {
            "path": { "const": "config/rule3-protocol.json" },
            "protocol_version": { "const": "rule3-1.0.0" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "models_config": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "config_version", "sha256"],
          "properties": {
            "path": { "const": "harness/config/models.json" },
            "config_version": { "const": "1.0.0" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "pricing_review": {
          "$ref": "#/$defs/binding",
          "properties": {
            "path": { "const": "harness/PRICING_REVIEW.md" }
          }
        },
        "lock_schema": {
          "$ref": "#/$defs/binding",
          "properties": {
            "path": { "const": "candidate/rule3-lock.schema.json" }
          }
        }
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "allOf": [
            { "$ref": "#/$defs/candidate" },
            {
              "properties": {
                "id": { "const": "galatians-pistis-christou" },
                "role": { "const": "priority" },
                "kind": { "const": "divergent" },
                "path": {
                  "const": "candidate/rule3/questions/galatians-pistis-christou.json"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/candidate" },
            {
              "properties": {
                "id": { "const": "quantum-measurement-realist-strategies" },
                "role": { "const": "fallback" },
                "kind": { "const": "divergent" },
                "path": {
                  "const": "candidate/rule3/questions/quantum-measurement-realist-strategies.json"
                }
              }
            }
          ]
        }
      ],
      "items": false
    },
    "models": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "prefixItems": [
        { "$ref": "#/$defs/gemini" },
        { "$ref": "#/$defs/claude" },
        { "$ref": "#/$defs/cohere" },
        { "$ref": "#/$defs/qwen" },
        { "$ref": "#/$defs/deepseek" },
        { "$ref": "#/$defs/mistral" },
        { "$ref": "#/$defs/grok" },
        { "$ref": "#/$defs/gpt" }
      ],
      "items": false
    },
    "plans": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "call_type",
        "variant_id",
        "candidate_plans",
        "ordered_universe_plan_sha256"
      ],
      "properties": {
        "call_type": { "const": "answer" },
        "variant_id": { "const": "default" },
        "candidate_plans": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "$ref": "#/$defs/candidate_plan",
              "properties": {
                "candidate_id": { "const": "galatians-pistis-christou" },
                "role": { "const": "priority" }
              }
            },
            {
              "$ref": "#/$defs/candidate_plan",
              "properties": {
                "candidate_id": {
                  "const": "quantum-measurement-realist-strategies"
                },
                "role": { "const": "fallback" }
              }
            }
          ],
          "items": false
        },
        "ordered_universe_plan_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "call_type",
        "cells_per_candidate",
        "attempts_per_cell",
        "output_token_cap",
        "candidate_cost_cap_microdollars",
        "total_cost_cap_microdollars",
        "tools_enabled",
        "web_search_enabled",
        "retrieval_enabled"
      ],
      "properties": {
        "call_type": { "const": "answer" },
        "cells_per_candidate": { "const": 8 },
        "attempts_per_cell": { "const": 3 },
        "output_token_cap": { "const": 16384 },
        "candidate_cost_cap_microdollars": { "const": 6000000 },
        "total_cost_cap_microdollars": { "const": 12000000 },
        "tools_enabled": { "const": false },
        "web_search_enabled": { "const": false },
        "retrieval_enabled": { "const": false }
      }
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_completed_responses",
        "minimum_non_null_primary_endorsements",
        "minimum_distinct_primary_positions",
        "maximum_primary_endorsements_per_position"
      ],
      "properties": {
        "required_completed_responses": { "const": 8 },
        "minimum_non_null_primary_endorsements": { "const": 6 },
        "minimum_distinct_primary_positions": { "const": 3 },
        "maximum_primary_endorsements_per_position": { "const": 4 }
      }
    },
    "state_transition_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_state",
        "transitions",
        "terminal_states",
        "fallback_requires_completed_priority_threshold_failure",
        "incomplete_is_not_threshold_failure",
        "third_candidate_forbidden"
      ],
      "properties": {
        "initial_state": {
          "const": "locked-awaiting-paid-authorization-and-pricing-recheck"
        },
        "transitions": {
          "type": "array",
          "minItems": 11,
          "maxItems": 11,
          "items": { "$ref": "#/$defs/transition" }
        },
        "terminal_states": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "fallback_requires_completed_priority_threshold_failure": {
          "const": true
        },
        "incomplete_is_not_threshold_failure": { "const": true },
        "third_candidate_forbidden": { "const": true }
      }
    },
    "paid_authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "separate_from_lock",
        "lock_authorizes_spending",
        "required_before_state",
        "receipt_must_bind",
        "immediate_price_and_availability_recheck_required"
      ],
      "properties": {
        "required": { "const": true },
        "separate_from_lock": { "const": true },
        "lock_authorizes_spending": { "const": false },
        "required_before_state": { "const": "priority-ready" },
        "receipt_must_bind": {
          "const": ["lock_sha256", "git_head"]
        },
        "immediate_price_and_availability_recheck_required": { "const": true }
      }
    },
    "execution_sources": {
      "type": "array",
      "minItems": 23,
      "items": { "$ref": "#/$defs/binding" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "kind", "path", "sha256"],
      "properties": {
        "id": { "type": "string" },
        "role": { "enum": ["priority", "fallback"] },
        "kind": { "const": "divergent" },
        "path": { "type": "string" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "requested_params": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "temperature",
        "output_limit",
        "reasoning",
        "tools_enabled",
        "web_search_enabled",
        "retrieval_enabled",
        "provider_options"
      ],
      "properties": {
        "temperature": { "type": "object" },
        "output_limit": {
          "type": "object",
          "required": ["sent", "parameter", "value"],
          "properties": {
            "sent": { "const": true },
            "parameter": { "enum": ["max_tokens", "max_output_tokens"] },
            "value": { "const": 16384 }
          }
        },
        "reasoning": { "type": "object" },
        "tools_enabled": { "const": false },
        "web_search_enabled": { "const": false },
        "retrieval_enabled": { "const": false },
        "provider_options": { "type": "object" }
