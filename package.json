{
  "name": "concordance-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "sample:data": "node scripts/create-sample-data.mjs",
    "validate:data": "tsx scripts/validate-data.ts --dataset sample",
    "validate:data:production": "tsx scripts/validate-data.ts --dataset data --production",
    "validate:candidates": "tsx scripts/validate-candidates.ts",
    "validate:candidates:successor": "tsx scripts/validate-successor-candidates.ts",
    "validate:candidates:author-verified": "tsx scripts/validate-author-verified-successor.ts",
    "build": "npm run validate:data && tsc -b && cross-env VITE_DATASET=sample vite build",
    "build:production": "npm run validate:data:production && tsc -b && cross-env VITE_DATASET=production vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:harness": "python3 -m unittest discover -s harness/tests -v",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "harness:dry-run": "python3 harness/generate.py --dry-run",
    "check": "npm run validate:candidates && npm run validate:candidates:successor && npm run validate:candidates:author-verified && npm run lint && npm run test:harness && npm run test && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/newsreader": "5.2.10",
    "framer-motion": "12.42.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cross-env": "10.1.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.0.1",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
